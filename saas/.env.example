# Supabase — use a SEPARATE dev project here, never the production project.
# (Pointing dev at prod puts a prod service-role key on developer laptops.)
WISP_SUPABASE_URL=
WISP_SUPABASE_ANON_KEY=
WISP_SUPABASE_SERVICE_ROLE=

# NOTE: device enrolment secrets are now PER-TENANT and minted in the dashboard
# (Fleet -> Rotate enrol secret), stored hashed in the enrol_secrets table.
# There is no global WISP_ENROL_SECRET anymore.

# Optional: seeded demo workspace id (enables onboarding "Join Demo")
WISP_DEMO_TENANT_ID=

# Scheduled billing rollup (Vercel Cron -> /api/cron/rollup)
WISP_CRON_SECRET=

# Observability (optional handoff)
WISP_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Public site URL (invite links, auth redirects)
NEXT_PUBLIC_SITE_URL=

# Stripe (use a TEST key, sk_test_..., for development)
WISP_STRIPE_SECRET=
WISP_STRIPE_WEBHOOK_SECRET=

# Email (savings reports + invoices)
WISP_RESEND_KEY=
