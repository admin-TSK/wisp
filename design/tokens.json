{
  "$schema": "https://wisp.dev/schemas/design-tokens.json",
  "meta": {
    "name": "Wisp Design Tokens",
    "version": "1.0.0",
    "source": "apple_ui_ux_guideline.md",
    "note": "Single source of truth for web (shadcn/Tailwind) and native (SwiftUI). Apple-inspired: one accent, semantic status colors, role-based type scale, calm spacing."
  },
  "color": {
    "light": {
      "accent": "#0A84FF",
      "accentHover": "#0060DF",
      "success": "#1E8E3E",
      "warning": "#B25E00",
      "destructive": "#D70015",
      "bg": "#FFFFFF",
      "bgElevated": "#F5F5F7",
      "surface": "#FFFFFF",
      "border": "#D2D2D7",
      "textPrimary": "#1D1D1F",
      "textSecondary": "#6E6E73",
      "textTertiary": "#8E8E93"
    },
    "dark": {
      "accent": "#0A84FF",
      "accentHover": "#409CFF",
      "success": "#30D158",
      "warning": "#FF9F0A",
      "destructive": "#FF453A",
      "bg": "#000000",
      "bgElevated": "#1C1C1E",
      "surface": "#161618",
      "border": "#38383A",
      "textPrimary": "#F5F5F7",
      "textSecondary": "#AEAEB2",
      "textTertiary": "#8E8E93"
    },
    "rule": "Never communicate status with color alone (guideline 3.2). Pair every semantic color with text and/or an SF Symbol."
  },
  "typography": {
    "fontFamily": {
      "sans": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', system-ui, sans-serif",
      "mono": "'SF Mono', ui-monospace, 'JetBrains Mono', monospace"
    },
    "roles": {
      "largeTitle": { "size": 34, "weight": 700, "lineHeight": 41, "use": "Savings dollar headline; major screen title" },
      "title": { "size": 28, "weight": 700, "lineHeight": 34, "use": "Page / panel title" },
      "title2": { "size": 22, "weight": 600, "lineHeight": 28, "use": "Section title" },
      "headline": { "size": 17, "weight": 600, "lineHeight": 22, "use": "Important grouped content" },
      "body": { "size": 17, "weight": 400, "lineHeight": 22, "use": "Main readable content" },
      "callout": { "size": 16, "weight": 400, "lineHeight": 21, "use": "Supporting explanation" },
      "caption": { "size": 13, "weight": 400, "lineHeight": 18, "use": "Metadata, hints, secondary labels" },
      "footnote": { "size": 12, "weight": 400, "lineHeight": 16, "use": "Low-priority supporting info" }
    },
    "rule": "Support Dynamic Type (native) and rem-based scaling (web). No fixed pixel sizes that break larger text."
  },
  "spacing": {
    "scale": { "xs": 4, "sm": 8, "md": 12, "base": 16, "lg": 24, "xl": 32, "2xl": 48, "3xl": 80, "4xl": 112 },
    "rule": "Calm by default; dashboard tables may use denser rows (data-heavy allowance). Keep destructive actions away from primary actions."
  },
  "radius": { "sm": 6, "md": 10, "lg": 14, "xl": 18, "2xl": 24, "pill": 999 },
  "elevation": {
    "rule": "Liquid Glass only on native popover/toolbars where it improves structure and stays readable; respect Reduce Transparency. On web, prefer solid surfaces over heavy blur.",
    "shadowSm": "0 1px 2px rgba(0,0,0,0.08)",
    "shadowMd": "0 4px 16px rgba(0,0,0,0.12)"
  },
  "motion": {
    "fast": 150,
    "base": 250,
    "rule": "Motion explains cause/effect; fast and purposeful. Respect Reduce Motion."
  }
}
